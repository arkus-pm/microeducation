{
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "minimum": 0,
      "default": 1.0
    },
    "contentURL": {
      "type": "string"
    },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "flowTopic": {
            "type": "string",
            "default": "newTopic"
          },
          "version": {
            "type": "number",
            "default": 1,
            "minimum": 0
          },
          "id": {
            "type": "string",
            "default": "$uuid"
          },
          "card": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "default": "New card title"
              },
              "imageURL": {
                "type": "string",
                "default": "https://i.onthe.io/ttmdhw747dgvun60p.f9d74fae.jpeg"
              },
              "description": {
                "type": "string",
                "default": "New card description"
              }
            },
            "required": [
              "title",
              "imageURL",
              "description"
            ]
          },
          "preview": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "default": "New preview title"
              },
              "imageURL": {
                "type": "string",
                "default": "https://i.onthe.io/ttmdhw747dgvun60p.f9d74fae.jpeg"
              },
              "overview": {
                "type": "string",
                "default": "New preview overview"
              }
            },
            "required": [
              "title",
              "imageURL",
              "overview"
            ]
          },
          "episodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "default": "$uuid"
                },
                "position": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 1
                },
                "title": {
                  "type": "string",
                  "default": "New episode title"
                },
                "description": {
                  "type": "string",
                  "default": "New episode description"
                },
                "stories": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "default": "$uuid"
                      },
                      "version": {
                        "type": "number",
                        "minimum": 0,
                        "default": 1.0
                      },
                      "position": {
                        "type": "integer",
                        "minimum": 0,
                        "default": 1
                      },
                      "transition": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "variation": "string",
                            "enum": ["fade_in"]
                          }
                        },
                        "required": [
                          "type"
                        ]
                      },
                      "content": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string"
                          },
                          "illustrationURL": {
                            "type": "string"
                          },
                          "text": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "type",
                          "illustrationURL",
                          "text"
                        ]
                      }
                    },
                    "required": [
                      "id",
                      "version",
                      "position",
                      "transition",
                      "content"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "position",
                "title",
                "description",
                "stories"
              ]
            }
          }
        },
        "required": [
          "version",
          "id",
          "flowTopic",
          "card",
          "preview",
          "episodes"
        ]
      }
    }
  },
  "required": [
    "version",
    "courses"
  ]
}