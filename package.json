    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/uuid": "^8.3.4",
    "cypress": "^6.1.0",
    "gh-pages": "^3.2.3",
    "react-scripts": "^4.0.1",
    "start-server-and-test": "^1.11.6"
  },
  "scripts": {
    "predeploy": "npm run build",
